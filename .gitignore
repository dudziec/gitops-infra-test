*.local.yaml
*.local.yml
secrets.yaml
secrets.yml
*-secret.yaml
*-secret.yml
kubeconfig
kubeconfig.*

# ─── Secrets / Credentials ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Archives ────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.rar
