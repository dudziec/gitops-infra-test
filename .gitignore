**/target/quarkus/
**/target/classes/
**/target/generated-sources/
**/target/generated-test-sources/
**/target/test-classes/
**/target/surefire-reports/
**/target/build-metrics.json
**/target/quarkus-artifact.properties
.quarkus/

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.code-workspace
.classpath
.project
.settings/
.factorypath
nbproject/
nb-configuration.xml

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── Kubernetes / GitOps ─────────────────────────────────────────────────────
